# =============================================================================
# AlgoTradeAI Dashboard — Environment Variables
# =============================================================================
# Copy to .env.local for local development: cp .env.example .env.local
# For production: set these in Cloudflare Pages dashboard under
#   Settings → Environment Variables → Production
# =============================================================================

# Your deployed Cloudflare Worker base URL (no trailing slash)
VITE_WORKER_URL=https://algo-trade-ai.yourname.workers.dev

# Internal API key — must match ALGO_API_KEY secret set in Cloudflare Workers
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_API_KEY=your_64_char_hex_api_key_here
